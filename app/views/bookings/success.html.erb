<% content_for :title, "Reservation received — Unveiled Paris" %>

<nav style="padding:20px 32px; border-bottom:1px solid var(--border);">
  <span class="serif" style="font-size:13px; letter-spacing:0.12em; text-transform:uppercase; color:var(--parchment);">
    <%= link_to "Unveiled Paris", root_path %>
  </span>
</nav>

<div style="max-width:520px; margin:120px auto; padding:0 32px; text-align:center;">
  <h1 class="serif" style="font-size:36px; font-weight:400; color:var(--parchment); margin:0 0 20px;">You are all set.</h1>
  <p style="font-size:15px; color:var(--dim); line-height:1.8; margin:0 0 12px;">
    We have your reservation. A confirmation will be in your inbox within a few hours.
  </p>
  <p style="font-size:14px; color:var(--dim); line-height:1.8; margin:0 0 48px;">
    If anything changes or you have questions, reach us at hello@unveiledparis.com.
  </p>
  <%= link_to "Back to home", root_path, style: "font-size:13px; color:var(--brass); border-bottom:1px solid rgba(185,151,90,0.4); padding-bottom:1px;" %>
</div>
