<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Unveiled Paris" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Unveiled Paris — private guided tours for American visitors. Hidden neighborhoods, long lunches, no crowds.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= yield :head %>
  </head>
  <body style="background:#0e0e0e; color:#e8e0d0; font-family:system-ui,-apple-system,sans-serif; font-size:15px; line-height:1.65;">
    <%= yield %>
  </body>
</html>
